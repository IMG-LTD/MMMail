{
  "name": "mmmail-frontend-v2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "typecheck": "vue-tsc --noEmit",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "node --test tests/*.test.mjs",
    "test:unit": "MMMAIL_VITEST_SUITE=unit vitest run --coverage --config vitest.config.ts",
    "test:component": "MMMAIL_VITEST_SUITE=component vitest run --coverage --config vitest.config.ts",
    "test:coverage": "pnpm test:unit && pnpm test:component",
    "visual:qa": "node scripts/v21-browser-visual-qa.mjs"
  },
  "dependencies": {
    "@vueuse/core": "^12.8.2",
    "echarts": "^5.5.1",
    "naive-ui": "^2.44.1",
    "openpgp": "^6.1.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.6",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.49.0",
    "typescript": "^5.7.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.6",
    "vue-tsc": "^2.2.0"
  }
}
