{
  "name": "mmmail-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "node ./scripts/nuxt-command.mjs prepare",
    "dev": "node ./scripts/nuxt-command.mjs dev --host 127.0.0.1 --port 3001",
    "build": "node ./scripts/nuxt-command.mjs build",
    "preview": "node ./scripts/nuxt-command.mjs preview --host 127.0.0.1 --port 3001",
    "i18n:test": "node ./scripts/nuxt-command.mjs prepare --logLevel silent && vitest run tests/i18n.spec.ts tests/i18n-governance.spec.ts tests/i18n-coverage.spec.ts tests/i18n-surface-governance.spec.ts tests/suite-operations-i18n.spec.ts tests/contacts-i18n.spec.ts tests/mail-compose-i18n.spec.ts tests/mail-workspace-i18n.spec.ts",
    "i18n:catalog": "node --experimental-strip-types ./scripts/i18n-report.mjs",
    "i18n:coverage": "node --experimental-strip-types ./scripts/i18n-coverage-report.mjs",
    "i18n:check": "pnpm run i18n:test && pnpm run i18n:catalog && pnpm run i18n:coverage",
    "test": "node ./scripts/nuxt-command.mjs prepare --logLevel silent && vitest run",
    "test:watch": "vitest",
    "typecheck": "node ./scripts/nuxt-command.mjs typecheck"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.9.0",
    "@unocss/nuxt": "^66.6.2",
    "@vueuse/core": "^12.8.2",
    "axios": "^1.7.9",
    "element-plus": "~2.9.8",
    "nuxt": "~3.21.1",
    "openpgp": "^6.3.0",
    "pinia": "^2.3.1",
    "vue": "~3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^15.11.7",
    "playwright-core": "1.52.0",
    "typescript": "^5.7.3",
    "unocss": "^66.6.2",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  },
  "pnpm": {
    "overrides": {
      "h3": "^1.15.6",
      "lodash": "^4.18.1",
      "lodash-es": "^4.18.1",
      "node-forge": "^1.4.0",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "serialize-javascript": "^7.0.3",
      "svgo": "^4.0.1",
      "tar": "^7.5.11"
    }
  }
}
