    "pinia": "^2.3.1",
    "vue": "~3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@types/node": "^22.10.5",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^15.11.7",
    "playwright-core": "1.52.0",
    "typescript": "^5.7.3",
    "unocss": "^66.6.2",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  },
  "pnpm": {
