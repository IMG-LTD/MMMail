# MMMail Docker 环境变量模板文件
# 复制此文件为 .env 并根据实际情况填写配置

# 数据库配置
MYSQL_ROOT_PASSWORD=mmmail123
MYSQL_DATABASE=mmmail
MYSQL_USER=mmmail
MYSQL_PASSWORD=mmmail123

# Redis 配置
REDIS_PASSWORD=

# 应用端口配置
NGINX_PORT=8080
BACKEND_PORT=1024
MYSQL_PORT=3306
REDIS_PORT=6379

# 应用配置
SPRING_PROFILES_ACTIVE=docker

# 邮件配置 (可选)
MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_USERNAME=your-email@163.com
MAIL_PASSWORD=your-password

# 日志级别
LOG_LEVEL=INFO

# JVM 参数
JAVA_OPTS=-Xmx512m -Xms256m

# 时区设置
TZ=Asia/Shanghai
