# MMMail Docker 环境变量模板文件
# 复制此文件为 .env 并根据实际情况填写配置

# ===========================================
# 数据库配置
# ===========================================
MYSQL_ROOT_PASSWORD=mmmail123
MYSQL_DATABASE=mmmail_admin_v3
MYSQL_USER=mmmail
MYSQL_PASSWORD=mmmail123

# ===========================================
# Redis 配置
# ===========================================
REDIS_PASSWORD=

# ===========================================
# 应用端口配置
# ===========================================
NGINX_PORT=8080
BACKEND_PORT=1024
SERVER_PORT=1024
MYSQL_PORT=3306
REDIS_PORT=6379

# ===========================================
# Spring 应用配置
# ===========================================
SPRING_PROFILES_ACTIVE=prod

# Spring 数据库连接配置
SPRING_DATASOURCE_URL=jdbc:p6spy:mysql://mysql:3306/mmmail_admin_v3?autoReconnect=true&useServerPreparedStmts=false&rewriteBatchedStatements=true&characterEncoding=UTF-8&useSSL=false&allowMultiQueries=true&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=mmmail
SPRING_DATASOURCE_PASSWORD=mmmail123
SPRING_DATASOURCE_DRIVER=com.p6spy.engine.spy.P6SpyDriver

# Spring Redis 连接配置
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_DATABASE=1
SPRING_REDIS_PASSWORD=
SPRING_REDIS_TIMEOUT=10000ms

# ===========================================
# 邮件配置
# ===========================================
SPRING_MAIL_HOST=mail.mmmail.com
SPRING_MAIL_PORT=465
SPRING_MAIL_USERNAME=notice@mmmail.com
SPRING_MAIL_PASSWORD=

# 兼容旧版本的邮件配置变量
MAIL_HOST=mail.mmmail.com
MAIL_PORT=465
MAIL_USERNAME=notice@mmmail.com
MAIL_PASSWORD=

# ===========================================
# 系统配置
# ===========================================
# 日志级别
LOG_LEVEL=INFO

# JVM 参数 (生产环境建议增大内存)
JAVA_OPTS=-Xmx1g -Xms512m

# 时区设置
TZ=Asia/Shanghai

# ===========================================
# 文件上传配置
# ===========================================
FILE_UPLOAD_PATH=/app/uploads

# ===========================================
# 安全配置 (生产环境请修改这些密码)
# ===========================================
# Druid 监控密码
DRUID_USERNAME=admin
DRUID_PASSWORD=admin123

# API 文档访问密码 (建议生产环境关闭或设置强密码)
API_DOC_USERNAME=api
API_DOC_PASSWORD=1024
