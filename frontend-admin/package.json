{
  "name": "soybean-admin",
  "version": "2.2.0",
  "description": "A fresh and elegant admin template, based on Vue3、Vite8、TypeScript、NaiveUI and UnoCSS. 一个基于Vue3、Vite8、TypeScript、NaiveUI and UnoCSS的清新优雅的中后台模版。",
  "keywords": [
    "TypeScript",
    "UnoCSS",
    "Vite8",
    "Vue3 admin ",
    "ant-design-vue v4",
    "naive-ui",
    "naive-ui-admin",
    "vue-admin-template"
  ],
  "homepage": "https://github.com/soybeanjs/soybean-admin",
  "bugs": {
    "url": "https://github.com/soybeanjs/soybean-admin/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Soybean",
    "email": "soybeanjs@outlook.com",
    "url": "https://github.com/soybeanjs"
  },
  "repository": {
    "url": "https://github.com/soybeanjs/soybean-admin.git"
  },
  "type": "module",
  "scripts": {
    "build": "vite build --mode prod && node scripts/normalize-generated-types.mjs",
    "build:test": "vite build --mode test && node scripts/normalize-generated-types.mjs",
    "check:bundle-budget": "pnpm build && node scripts/check-bundle-budget.mjs && size-limit",
    "check:i18n": "tsx scripts/check-i18n-keys.ts",
    "check:style-discipline": "node scripts/check-style-discipline.mjs",
    "cleanup": "sa cleanup",
    "commit": "sa git-commit",
    "commit:zh": "sa git-commit -l=zh-cn",
    "dev": "vite --mode test",
    "dev:prod": "vite --mode prod",
    "fmt": "oxfmt",
    "gen-route": "sa gen-route",
    "gen:api": "node scripts/gen-api.mjs",
    "lint": "oxlint --fix && eslint --fix .",
    "prepare": "simple-git-hooks",
    "preview": "vite preview",
    "release": "sa release",
    "test:component": "MMMAIL_VITEST_SUITE=component vitest run --coverage --config vitest.config.ts",
    "test:coverage": "pnpm test:unit && pnpm test:component",
    "test:e2e": "playwright test",
    "test:lighthouse": "node scripts/run-lighthouse.mjs",
    "test:unit": "MMMAIL_VITEST_SUITE=unit vitest run --coverage --config vitest.config.ts",
    "test:v212": "node --test tests/*.test.mjs",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "update-pkg": "sa update-pkg"
  },
  "dependencies": {
    "@better-scroll/core": "2.5.1",
    "@iconify/vue": "5.0.1",
    "@sa/axios": "workspace:*",
    "@sa/color": "workspace:*",
    "@sa/hooks": "workspace:*",
    "@sa/materials": "workspace:*",
    "@sa/utils": "workspace:*",
    "@tiptap/extension-collaboration": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@tiptap/vue-3": "^3.23.4",
    "@vueuse/core": "14.3.0",
    "clipboard": "2.0.11",
    "dayjs": "1.11.20",
    "defu": "6.1.7",
    "echarts": "6.0.0",
    "json5": "2.2.3",
    "naive-ui": "2.44.1",
    "nprogress": "0.2.0",
    "pinia": "3.0.4",
    "tailwind-merge": "3.6.0",
    "vue": "3.5.34",
    "vue-draggable-plus": "0.6.1",
    "vue-i18n": "11.4.2",
    "vue-router": "5.0.7",
    "y-prosemirror": "^1.3.7",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@elegant-router/vue": "0.3.8",
    "@iconify/json": "2.2.472",
    "@playwright/test": "^1.60.0",
    "@sa/scripts": "workspace:*",
    "@sa/uno-preset": "workspace:*",
    "@size-limit/file": "12.1.0",
    "@soybeanjs/eslint-config-vue": "^0.0.2",
    "@types/node": "25.7.0",
    "@types/nprogress": "0.2.3",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "@vitest/coverage-v8": "^4.1.6",
    "@vue/test-utils": "^2.4.10",
    "consola": "3.4.2",
    "eslint": "10.3.0",
    "jsdom": "^29.1.1",
    "kolorist": "1.8.0",
    "lighthouse": "^13.3.0",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "sass": "1.99.0",
    "simple-git-hooks": "2.13.1",
    "size-limit": "12.1.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "unocss": "^66.6.8",
    "unplugin-icons": "23.0.1",
    "unplugin-vue-components": "32.0.0",
    "vite": "8.0.12",
    "vite-plugin-bundle-analyzer": "0.0.1",
    "vite-plugin-progress": "0.0.7",
    "vite-plugin-svg-icons": "2.0.1",
    "vite-plugin-vue-devtools": "8.1.2",
    "vite-plugin-vue-transition-root-validator": "^0.1.0",
    "vitest": "^4.1.6",
    "vue-tsc": "3.2.8"
  },
  "simple-git-hooks": {
    "commit-msg": "cd frontend-admin && pnpm sa git-commit-verify",
    "pre-commit": "pnpm --dir frontend-admin typecheck && pnpm --dir frontend-admin exec oxlint && pnpm --dir frontend-admin exec eslint . && pnpm --dir frontend-admin exec oxfmt --check && git diff --exit-code"
  },
  "size-limit": [
    {
      "name": "workspace first screen route chunk",
      "path": [
        "dist/assets/home-*.js",
        "dist/assets/index-*.css"
      ],
      "limit": "500 KB"
    },
    {
      "name": "wallet route chunk",
      "path": "dist/assets/wallet-*.js",
      "limit": "200 KB"
    },
    {
      "name": "vpn route chunk",
      "path": "dist/assets/vpn-*.js",
      "limit": "150 KB"
    },
    {
      "name": "meet route chunk",
      "path": "dist/assets/meet-*.js",
      "limit": "350 KB"
    },
    {
      "name": "docs route chunk",
      "path": "dist/assets/docs-*.js",
      "limit": "350 KB"
    },
    {
      "name": "sheets route chunk",
      "path": "dist/assets/sheets-*.js",
      "limit": "250 KB"
    }
  ],
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.5.0"
  },
  "website": "https://admin.soybeanjs.cn"
}
