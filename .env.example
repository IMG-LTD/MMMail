# MMMail unified environment template
# Copy this file to `.env.local` for local development if needed.

# Frontend v2
VITE_API_BASE_URL=http://localhost:8080

# Backend runtime
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
MMMAIL_JWT_SECRET=replace-with-32-plus-char-random-secret
MMMAIL_JWT_SECRET_FILE=
MMMAIL_CORS_ALLOWED_ORIGINS=http://localhost:9527,http://127.0.0.1:9527,http://localhost:9725,http://127.0.0.1:9725,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:3001,http://127.0.0.1:3001
MMMAIL_JWT_EXPIRE_MINUTES=15
MMMAIL_REFRESH_TOKEN_EXPIRE_HOURS=168
MMMAIL_AUTH_REFRESH_COOKIE_NAME=MMMAIL_REFRESH_TOKEN
MMMAIL_AUTH_CSRF_COOKIE_NAME=MMMAIL_CSRF_TOKEN
MMMAIL_AUTH_COOKIE_SECURE=false
MMMAIL_AUTH_COOKIE_SAME_SITE=Lax
MMMAIL_SECURITY_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
MMMAIL_SECURITY_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
MMMAIL_SECURITY_CLIENT_ERROR_RATE_LIMIT_WINDOW_SECONDS=60
MMMAIL_SECURITY_CLIENT_ERROR_RATE_LIMIT_MAX_EVENTS=30
MMMAIL_SECURITY_MAIL_SEND_RATE_LIMIT_WINDOW_SECONDS=60
MMMAIL_SECURITY_MAIL_SEND_RATE_LIMIT_MAX_EVENTS=30
MMMAIL_SECURITY_WEB_PUSH_TEST_RATE_LIMIT_WINDOW_SECONDS=60
MMMAIL_SECURITY_WEB_PUSH_TEST_RATE_LIMIT_MAX_EVENTS=5
MMMAIL_SECURITY_COMMAND_RUN_RATE_LIMIT_WINDOW_SECONDS=60
MMMAIL_SECURITY_COMMAND_RUN_RATE_LIMIT_MAX_EVENTS=10
MMMAIL_BILLING_WEBHOOK_SECRET=replace-with-32-plus-char-random-secret
MMMAIL_LICENSE_PUBLIC_KEY=
MMMAIL_PUBLIC_BASE_URL=http://localhost:3001
MMMAIL_OIDC_ENABLED=false
MMMAIL_OIDC_CALLBACK_PATH=/api/v2/auth/oidc/callback
MMMAIL_OIDC_CLIENT_SECRET=
MMMAIL_OTEL_ENABLED=false
MMMAIL_OTEL_SAMPLING_PROBABILITY=1.0
OTEL_SERVICE_NAME=mmmail-server
OTEL_TRACES_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=

# Backend infra
SPRING_DATASOURCE_DRIVER=com.mysql.cj.jdbc.Driver
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/mmmail?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=mmmail_app
SPRING_DATASOURCE_PASSWORD=replace-with-db-password
MYSQL_ROOT_PASSWORD=replace-with-mysql-root-password
SPRING_REDIS_HOST=127.0.0.1
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=replace-with-redis-password
SPRING_REDIS_DATABASE=0
SPRING_REDIS_TIMEOUT=5s
MMMAIL_NACOS_ENABLED=false
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_USERNAME=replace-with-nacos-user
NACOS_PASSWORD=replace-with-nacos-password
NACOS_AUTH_TOKEN=replace-with-32-plus-char-random-secret
NACOS_AUTH_IDENTITY_KEY=replace-with-nacos-identity-key
NACOS_AUTH_IDENTITY_VALUE=replace-with-nacos-identity-value
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP
SPRING_SQL_INIT_MODE=never
SPRING_SQL_INIT_CONTINUE_ON_ERROR=true
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=20MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=25MB
MMMAIL_DRIVE_STORAGE_ROOT=/tmp/mmmail-drive-local
MMMAIL_DRIVE_RECYCLE_BIN_RETENTION_DAYS=30
MMMAIL_DRIVE_PUBLIC_SHARE_RATE_LIMIT_WINDOW_SECONDS=60
MMMAIL_DRIVE_PUBLIC_SHARE_RATE_LIMIT_MAX_REQUESTS=30
MMMAIL_DRIVE_PUBLIC_SHARE_RATE_LIMIT_REDIS_KEY_PREFIX=mmmail:drive:share-rate

# v2.1.2 realtime and external integrations
MMMAIL_WEBSOCKET_AFFINITY_COOKIE_NAME=WS_AFFINITY
MMMAIL_WEBSOCKET_AFFINITY_NODE_ID=mmmail-local
MMMAIL_WEBSOCKET_AFFINITY_COOKIE_SECURE=false
MMMAIL_WEBSOCKET_AFFINITY_COOKIE_MAX_AGE_SECONDS=604800
MMMAIL_WEBSOCKET_SESSION_MAX_IDLE_MS=300000
MMMAIL_WEBSOCKET_CONNECTION_MAX_ACTIVE=10000
MMMAIL_WEBSOCKET_CONNECTION_RETRY_AFTER_MS=1000
MMMAIL_WEBSOCKET_SUBSCRIPTION_MAX_CHANNELS_PER_SESSION=32
MMMAIL_WEBSOCKET_SUBSCRIPTION_RETRY_AFTER_MS=1000
MMMAIL_WEBSOCKET_RATE_LIMIT_WINDOW_SECONDS=1
MMMAIL_WEBSOCKET_RATE_LIMIT_MAX_MESSAGES_PER_WINDOW=100
MMMAIL_WEBSOCKET_RATE_LIMIT_RETRY_AFTER_MS=1000
MMMAIL_MAIL_EXTERNAL_ACCOUNT_SECRET=replace-with-32-plus-char-random-secret
MMMAIL_WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.test
MMMAIL_WEB_PUSH_VAPID_PUBLIC_KEY=
MMMAIL_WEB_PUSH_VAPID_PRIVATE_KEY=
MMMAIL_FEATURE_FLAGS_WATCH_INTERVAL_MS=5000

# v2.1.2 dev seed, used only with SPRING_PROFILES_ACTIVE=dev
MMMAIL_DEV_SEED_ENABLED=true
MMMAIL_DEV_SEED_WALLET=true
MMMAIL_DEV_SEED_MEET=true
MMMAIL_DEV_SEED_COMMUNITY=true
MMMAIL_DEV_SEED_SEARCH_INDEX=true
MMMAIL_DEV_SEED_DOMAIN=true
MMMAIL_DEV_SEED_WEBPUSH=false
