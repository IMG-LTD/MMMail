# EditorConfig keeps repository-wide formatting stable across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{js,mjs,ts,vue,json,yml,yaml,md,css,scss,html}]
indent_size = 2

[*.{java,xml}]
indent_size = 4

[*.{sh,sql}]
indent_size = 2

[Makefile]
indent_style = tab
