# Normalize text files to LF so shell scripts, CI config, docs, and tests behave
# consistently on Linux runners and developer machines.
* text=auto eol=lf

*.sh text eol=lf
*.bash text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.scss text eol=lf
pnpm-lock.yaml text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.jar binary
*.woff binary
*.woff2 binary
